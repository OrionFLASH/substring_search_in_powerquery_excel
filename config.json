{
  "output_file": "output/_base_gsz_keys.xlsx",
  "output_add_timestamp": true,
  "output_timestamp_format": "%Y%m%d_%H%M%S",
  "min_token_length": 2,
  "short_token_not_max_len": 5,
  "common_token_threshold": 80,
  "gsz_matcher_parallel": {
    "input_xlsx": "input/Tables+Holding.xlsx",
    "output_xlsx": "output/hold_od_gsz_python.xlsx",
    "output_add_timestamp": true,
    "output_timestamp_format": "%Y%m%d_%H%M%S",
    "holding_table": "_HOLD_OD",
    "base_table": "_base_gsz",
    "holding_column": "Холдинг",
    "holding_id_column": "ID холдинга",
    "gsz_column": "Наименование, регион",
    "and_full_cols": [
      "key_and_full_1",
      "key_and_full_2",
      "key_and_full_3"
    ],
    "and_not_cols": [
      "key_and_not_1",
      "key_and_not_2",
      "key_and_not_3"
    ],
    "and_non_cols": [
      "key_and_non_1",
      "key_and_non_2"
    ],
    "or_full_cols": [
      "key_or_full_1",
      "key_or_full_2",
      "key_or_full_3"
    ],
    "or_not_cols": [
      "key_or_not_1",
      "key_or_not_2",
      "key_or_not_3"
    ],
    "or_non_cols": [
      "key_or_non_1",
      "key_or_non_2"
    ],
    "_docs": {
      "prefilter": "AND: один якорь. Только OR: все токены из or_full_cols/or_not_cols (достаточно любого). Согласовано с PQ FAST/FAST_V2."
    },
    "fix_id_col": "key_fix_id",
    "match_status_texts": {
      "none": "-",
      "single": "найдено соответствие",
      "fixed": "зафиксированное значение",
      "multiple": "есть пересечения по ключам",
      "fix_not_found": "фикс значение не найдено",
      "fix_partial": "найдена часть фиксированных значений",
      "multiple_placeholder": ":=>"
    },
    "workers": 8,
    "work_batch_size": 30,
    "log_stages": true,
    "progress_every_holdings": 100,
    "progress_every_base_rows": 150,
    "progress_every_batches": 25,
    "progress_every_read_rows": 500,
    "heartbeat_seconds": 10,
    "show_current_holding": true,
    "diagnose_workbook_objects": true,
    "log_to_file": true,
    "logs_dir": "LOGS",
    "log_file_prefix": "gsz_matcher_parallel",
    "output_format": {
      "header_center": true,
      "header_wrap": true,
      "header_bold": true,
      "holding_freeze_rows": 1,
      "holding_freeze_cols": 3,
      "base_freeze_rows": 1,
      "base_freeze_cols": 3,
      "min_width_all": 30,
      "format_data_vertical_center": true,
      "holding_sheet": {
        "columns": {
          "gsz_primary": {"name": "Бренд", "width": 100},
          "gsz_debug": {"name": "Отладка_совпадения_Бренд", "width": 150, "wrap": true},
          "match_status": {"name": "статус", "width": 40, "wrap": true},
          "match_count": {"name": "Кол-во совпадений", "width": 30}
        }
      },
      "base_sheet": {
        "columns": {
          "holding_count": {"name": "кол-во холдингов", "width": 30},
          "found_holding": {"name": "найденный холдинг", "width": 100},
          "found_holding_debug": {"name": "Отладка_найденного_холдинга", "width": 150, "wrap": true},
          "match_status": {"name": "статус", "width": 40, "wrap": true},
          "key_string": {"name": "строка ключа", "width": 30},
          "key_length": {"name": "длина ключа", "width": 30},
          "key_repeat_count": {"name": "число повторов", "width": 30}
        }
      }
    }
  }
}
